{"file":"login-dywHJmwk.js","mappings":";;;;;;;;;;;;;;;;;;;AACA,UAAM,QAAQ,IAAI,EAAE;AACpB,UAAM,WAAW,IAAI,EAAE;AACN,sBAAA;;mBAOVA,eAAAC,WAAA,EAAA,OAAM,8DAA0D,MAAA,CAAA,gJAGjDC,MAAA,KAAA,CAAK,gGACLA,MAAA,QAAA,CAAQ;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_unref"],"sources":["../../../../app/pages/login.vue"],"sourcesContent":["<script setup lang=\"ts\">\nconst email = ref('')\nconst password = ref('')\nconst supabase = useSupabaseClient()\nconst handleLogin = async () => {\n  const { error } = await supabase.auth.signInWithPassword({ email: email.value, password: password.value })\n  if (!error) navigateTo('/')\n}\n</script>\n<template>\n  <div class=\"min-h-screen flex items-center justify-center bg-gray-50\">\n    <div class=\"w-full max-w-md bg-white p-8 rounded-3xl shadow-sm\">\n      <h1 class=\"text-2xl font-bold mb-6\">Login</h1>\n      <input v-model=\"email\" class=\"w-full p-4 mb-4 border rounded-xl\" placeholder=\"Email\" />\n      <input v-model=\"password\" type=\"password\" class=\"w-full p-4 mb-6 border rounded-xl\" placeholder=\"Password\" />\n      <button @click=\"handleLogin\" class=\"w-full py-4 bg-[#003366] text-white rounded-xl font-bold\">Masuk</button>\n    </div>\n  </div>\n</template>\n"],"version":3}